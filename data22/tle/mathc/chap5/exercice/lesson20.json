    "niveau": "hard",
    "enonce": {
      "texte": "<p>La population d'une ville (en milliers d'habitants) a été relevée tous les 5 ans :</p><table style='border-collapse: collapse; width: 100%; margin: 10px 0;'><tr style='background-color: #f2f2f2;'><th style='border: 1px solid #ddd; padding: 8px; text-align: center;'>Année</th><th style='border: 1px solid #ddd; padding: 8px; text-align: center;'>1980</th><th style='border: 1px solid #ddd; padding: 8px; text-align: center;'>1985</th><th style='border: 1px solid #ddd; padding: 8px; text-align: center;'>1990</th><th style='border: 1px solid #ddd; padding: 8px; text-align: center;'>1995</th><th style='border: 1px solid #ddd; padding: 8px; text-align: center;'>2000</th><th style='border: 1px solid #ddd; padding: 8px; text-align: center;'>2005</th></tr><tr><th style='border: 1px solid #ddd; padding: 8px; text-align: center;'>Population</th><td style='border: 1px solid #ddd; padding: 8px; text-align: center;'>100</td><td style='border: 1px solid #ddd; padding: 8px; text-align: center;'>115</td><td style='border: 1px solid #ddd; padding: 8px; text-align: center;'>130</td><td style='border: 1px solid #ddd; padding: 8px; text-align: center;'>150</td><td style='border: 1px solid #ddd; padding: 8px; text-align: center;'>170</td><td style='border: 1px solid #ddd; padding: 8px; text-align: center;'>195</td></tr></table>",
      "images": []
