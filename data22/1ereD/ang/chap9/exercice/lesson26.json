          {
            "numero": "1.B",
            "texte": "A ten-minute break",
            "niveau": "easy",
            "reponse": "Correct: Number \u002B singular noun \u002B noun."
          },
          {
            "numero": "1.C",
            "texte": "A ten minute\u0027s break",
            "niveau": "easy",
            "reponse": "Incorrect: Possessive form is not used here."
