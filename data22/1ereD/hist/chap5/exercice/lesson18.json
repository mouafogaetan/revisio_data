    "questions": [
      {
        "numero": 1,
        "texte": "D\u0027apr\u00E8s le document, expliquer le principe du syst\u00E8me d\u0027Indirect Rule.",
        "niveau": "medium",
        "reponse": "Le syst\u00E8me d\u0027Indirect Rule consistait \u00E0 gouverner les populations locales par l\u0027interm\u00E9diaire de leurs propres chefs traditionnels, qui \u00E9taient int\u00E9gr\u00E9s dans l\u0027administration coloniale britannique.",
        "sousQuestions": [
          {
            "numero": "1.a",
            "texte": "Identifier deux responsabilit\u00E9s confi\u00E9es aux chefs indig\u00E8nes selon ce rapport.",
            "niveau": "easy",
            "reponse": "Percevoir les imp\u00F4ts et recruter la main-d\u0027\u0153uvre pour les travaux publics (ou rendre la justice)."
          },
          {
            "numero": "1.b",
            "texte": "Comparer bri\u00E8vement ce syst\u00E8me avec l\u0027administration directe fran\u00E7aise (Le\u00E7on 20) concernant la place des \u00E9lites locales.",
            "niveau": "hard",
            "reponse": "Alors que l\u0027administration fran\u00E7aise (directe) cherchait \u00E0 assimiler les \u00E9lites locales et \u00E0 supprimer les chefferies traditionnelles au profit d\u0027une administration centralis\u00E9e fran\u00E7aise, le syst\u00E8me britannique (Indirect Rule) maintenait et utilisait les structures de chefferie existantes comme rouages de l\u0027administration coloniale."
          }
        ]
      }
    ]
