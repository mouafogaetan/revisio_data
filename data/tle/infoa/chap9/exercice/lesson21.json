        "texte": "<div style='font-family: -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, Oxygen, Ubuntu, Cantarell, \"Helvetica Neue\", sans-serif; line-height: 1.6; color: #333;'><p>Écrivez une requête SQL pour afficher le prix moyen des produits de chaque catégorie.</p></div>",
        "niveau": "very hard",
        "reponse": "<div style='font-family: -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, Oxygen, Ubuntu, Cantarell, \"Helvetica Neue\", sans-serif; line-height: 1.6; color: #333;'><p><code>SELECT Categorie, AVG(Prix) AS PrixMoyen FROM Produits GROUP BY Categorie;</code></p></div>",
        "sousQuestions": [
          {
            "numero": "1.a",
            "texte": "<div style='font-family: -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, Oxygen, Ubuntu, Cantarell, \"Helvetica Neue\", sans-serif; line-height: 1.6; color: #333;'><p>Écrivez une requête SQL pour afficher le nombre total de produits par catégorie.</p></div>",
            "niveau": "very hard",
            "reponse": "<div style='font-family: -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, Oxygen, Ubuntu, Cantarell, \"Helvetica Neue\", sans-serif; line-height: 1.6; color: #333;'><p><code>SELECT Categorie, COUNT(*) AS NombreProduits FROM Produits GROUP BY Categorie;</code></p></div>"
          },
