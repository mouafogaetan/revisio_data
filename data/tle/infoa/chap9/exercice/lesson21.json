    "questions": [
      {
        "numero": 1,
        "texte": "<div style='font-family: -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, Oxygen, Ubuntu, Cantarell, \"Helvetica Neue\", sans-serif; line-height: 1.6; color: #333;'><p>Écrivez une requête SQL pour afficher le chiffre d'affaires total (Prix × Quantité) par produit.</p></div>",
        "niveau": "very hard",
        "reponse": "<div style='font-family: -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, Oxygen, Ubuntu, Cantarell, \"Helvetica Neue\", sans-serif; line-height: 1.6; color: #333;'><p><code>SELECT P.Nom, SUM(P.Prix * V.Quantite) AS ChiffreAffaires FROM Produits P JOIN Ventes V ON P.Id = V.ProduitId GROUP BY P.Id, P.Nom;</code></p></div>",
        "sousQuestions": [
          {
            "numero": "1.a",
            "texte": "<div style='font-family: -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, Oxygen, Ubuntu, Cantarell, \"Helvetica Neue\", sans-serif; line-height: 1.6; color: #333;'><p>Écrivez une requête SQL pour afficher les produits qui ont été vendus plus de 3 fois (quantité totale supérieure à 3).</p></div>",
            "niveau": "very hard",
            "reponse": "<div style='font-family: -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, Oxygen, Ubuntu, Cantarell, \"Helvetica Neue\", sans-serif; line-height: 1.6; color: #333;'><p><code>SELECT P.Nom, SUM(V.Quantite) AS TotalVendu FROM Produits P JOIN Ventes V ON P.Id = V.ProduitId GROUP BY P.Id, P.Nom HAVING SUM(V.Quantite) > 3;</code></p></div>"
          },
          {
            "numero": "1.b",
            "texte": "<div style='font-family: -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, Oxygen, Ubuntu, Cantarell, \"Helvetica Neue\", sans-serif; line-height: 1.6; color: #333;'><p>Écrivez une requête SQL pour afficher la date de la première vente de chaque produit.</p></div>",
            "niveau": "very hard",
            "reponse": "<div style='font-family: -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, Oxygen, Ubuntu, Cantarell, \"Helvetica Neue\", sans-serif; line-height: 1.6; color: #333;'><p><code>SELECT P.Nom, MIN(V.DateVente) AS PremiereVente FROM Produits P JOIN Ventes V ON P.Id = V.ProduitId GROUP BY P.Id, P.Nom;</code></p></div>"
          }
        ]
      }
    ]
