        ]
      },
      {
        "numero": 2,
        "texte": "Calculer $\\sin\\alpha$ sachant que $\\cos\\alpha = \\frac{\\sqrt{3}}{2}$.",
        "niveau": "easy",
        "reponse": "$\\sin\\alpha = \\frac{1}{2}$.",
        "sousQuestions": [
          {
            "numero": "2.a",
            "texte": "Exprimer $\\sin^2\\alpha$ en fonction de $\\cos^2\\alpha$.",
            "niveau": "easy",
            "reponse": "$\\sin^2\\alpha = 1 - \\cos^2\\alpha$."
          },
          {
            "numero": "2.b",
            "texte": "Calculer $\\sin^2\\alpha$ puis $\\sin\\alpha$.",
            "niveau": "easy",
            "reponse": "$\\sin^2\\alpha = 1 - (\\frac{\\sqrt{3}}{2})^2 = 1 - \\frac{3}{4} = \\frac{1}{4}$. Donc $\\sin\\alpha = \\frac{1}{2}$."
          }
        ]
      }
