      {
        "numero": 1,
        "texte": "Rappeler l\u0027expression du travail du poids lors d\u0027un d\u00E9placement $AB$ sur un plan inclin\u00E9.",
        "niveau": "easy",
        "reponse": "$W(\\vec{P}) = m g (z_A - z_B) = m g L \\sin \\alpha$",
        "sousQuestions": []
