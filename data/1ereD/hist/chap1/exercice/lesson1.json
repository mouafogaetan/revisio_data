    "questions": [
      {
        "numero": 1,
        "texte": "D\u00E9finis le terme \u0027Renaissance\u0027.",
        "niveau": "easy",
        "reponse": "La Renaissance est une p\u00E9riode de renouveau culturel, scientifique et artistique en Europe, marquant la transition entre le Moyen \u00C2ge et les Temps modernes."
      },
      {
        "numero": 2,
        "texte": "\u00C0 quel si\u00E8cle la Renaissance a-t-elle d\u00E9but\u00E9 et dans quel pays ?",
        "niveau": "easy",
        "reponse": "La Renaissance a d\u00E9but\u00E9 au XVIe si\u00E8cle (1500-1599), et son point de d\u00E9part est l\u0027Italie."
      },
      {
        "numero": 3,
        "texte": "Cite au moins trois facteurs ayant favoris\u00E9 l\u0027\u00E9mergence de la Renaissance.",
        "niveau": "easy",
        "reponse": "Facteurs de la Renaissance : 1) Red\u00E9couverte de la litt\u00E9rature, philosophie et sciences de l\u0027Antiquit\u00E9 ; 2) D\u00E9veloppement des m\u00E9thodes scientifiques ; 3) Progr\u00E8s des math\u00E9matiques (calculs num\u00E9riques et alg\u00E9briques) ; 4) Affaiblissement du contr\u00F4le de l\u0027\u00C9glise sur les id\u00E9es."
      },
      {
        "numero": 4,
        "texte": "Quelle invention majeure de la Renaissance a permis une large diffusion des id\u00E9es ?",
        "niveau": "easy",
        "reponse": "L\u2019imprimerie."
      }
