        "reponse": "$\\cos 2x = -\\frac{7}{25}$, $\\sin 2x = -\\frac{24}{25}$, $\\tan 2x = \\frac{24}{7}$",
        "sousQuestions": [
          {
            "numero": "2.a",
            "texte": "Calculer $\\cos 2x$.",
            "niveau": "easy",
            "reponse": "$\\cos 2x = \\cos^2 x - \\sin^2 x = (\\frac{3}{5})^2 - (-\\frac{4}{5})^2 = \\frac{9}{25} - \\frac{16}{25} = -\\frac{7}{25}$"
          },
          {
            "numero": "2.b",
            "texte": "Calculer $\\sin 2x$.",
            "niveau": "easy",
            "reponse": "$\\sin 2x = 2 \\sin x \\cos x = 2 \\times (-\\frac{4}{5}) \\times \\frac{3}{5} = -\\frac{24}{25}$"
          },
          {
            "numero": "2.c",
            "texte": "Calculer $\\tan 2x$.",
            "niveau": "medium",
            "reponse": "$\\tan 2x = \\frac{\\sin 2x}{\\cos 2x} = \\frac{-24/25}{-7/25} = \\frac{24}{7}$"
          }
        ]
      }
    ]
